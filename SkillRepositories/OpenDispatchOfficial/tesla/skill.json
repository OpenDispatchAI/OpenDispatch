{
  "skill_id": "tesla",
  "version": "1.0.0",
  "name": "Tesla",
  "bridge_shortcut_required": true,
  "bridge_shortcut_name": "OpenDispatch - Tesla",
  "bridge_shortcut_version": "1.0.0",
  "bridge_install_url": "https://www.icloud.com/shortcuts/REPLACE_ME",
  "bridge_setup_instructions": [
    "Install the shortcut in Apple Shortcuts.",
    "Open the shortcut once and connect it to the Tesla app actions you want to run.",
    "Set a default vehicle inside the shortcut if OpenDispatch does not supply one yet."
  ],
  "bridge_input_template": {
    "schema_version": 1,
    "skill_id": "{{skill_id}}",
    "skill_version": "{{skill_version}}",
    "action": "{{action}}",
    "params": "{{params}}"
  },
  "actions": [
    {
      "action": "vehicle.climate.start",
      "params_schema": {
        "vehicle": "string"
      },
      "keywords": ["tesla", "climate", "ac", "airco", "precondition", "heat"],
      "examples": [
        "turn on the car ac",
        "start tesla climate",
        "precondition the car"
      ],
      "title": "Start Climate"
    },
    {
      "action": "vehicle.lock",
      "params_schema": {
        "vehicle": "string"
      },
      "keywords": ["tesla", "lock", "secure"],
      "examples": [
        "lock the tesla",
        "lock my car"
      ],
      "title": "Lock Vehicle"
    },
    {
      "action": "vehicle.unlock",
      "params_schema": {
        "vehicle": "string"
      },
      "keywords": ["tesla", "unlock"],
      "examples": [
        "unlock the tesla",
        "unlock my car"
      ],
      "title": "Unlock Vehicle"
    }
  ],
  "priority": 70
}
